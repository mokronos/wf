{
  "name": "wf-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/wf build",
    "build:cli": "bun run --cwd packages/wf-cli build",
    "build:marketing": "bun run --cwd apps/marketing build",
    "cli": "bun run packages/wf/src/cli/main.ts",
    "dev:marketing": "bun run --cwd apps/marketing dev",
    "dev:cli": "bun run packages/wf-cli/src/main.ts",
    "example:email": "bun run examples/email/main.ts",
    "example:quickstart": "bun run examples/quickstart/main.ts",
    "example:order-saga": "cd examples/order-saga && bun run main.ts",
    "example:approval": "cd examples/approval && bun run main.ts demo",
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --build --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@types/bun": "latest",
    "effect-solutions": "^0.5.3",
    "typescript": "^6.0.3"
  }
}
